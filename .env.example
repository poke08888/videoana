# Khóa API Google Gemini — lấy tại https://aistudio.google.com/apikey
# Backend dùng key này để upload video lên Gemini và chạy mổ xẻ.
# Người dùng cũng có thể nhập key trong màn Quản trị (lưu trên trình duyệt),
# key đó sẽ được gửi kèm mỗi lần phân tích và ưu tiên hơn biến môi trường này.
GEMINI_API_KEY=

# Model phân tích video (mặc định theo skill Nonelab).
GEMINI_MODEL=gemini-3-flash-preview

# Cổng backend
PORT=8787

# Secret để ký JWT phiên đăng nhập (BẮT BUỘC đặt ở production).
# Sinh nhanh: openssl rand -hex 32
JWT_SECRET=

# Mật khẩu khởi tạo cho tài khoản admin mặc định (chỉ dùng khi seed lần đầu).
# Bỏ trống => backend tự sinh ngẫu nhiên và in ra console. Admin buộc phải
# đổi mật khẩu ngay ở lần đăng nhập đầu tiên.
ADMIN_INIT_PASSWORD=

# Số video xử lý SONG SONG cùng lúc trong hàng đợi nền (nhiều video/nhiều tài
# khoản tải lên). Cao hơn = nhanh hơn nhưng dễ vượt rate-limit/quota Gemini.
QUEUE_CONCURRENCY=10

# RapidAPI key cho tokapi-mobile-version — dùng để TỰ ĐỘNG TẢI video TikTok từ
# link người dùng dán vào. Lấy tại:
# https://rapidapi.com/Sonjik/api/tokapi-mobile-version
TOKAPI_RAPIDAPI_KEY=

# Video DOUYIN tải qua RapidAPI "douyin-api6" (TikHub team) — hệ thống tự nhận
# diện link douyin.com trong cùng ô nhập với TikTok. RapidAPI dùng CHUNG một key
# cho mọi API đã subscribe nên mặc định dùng lại TOKAPI_RAPIDAPI_KEY ở trên;
# chỉ đặt DOUYIN_RAPIDAPI_KEY nếu muốn dùng key/tài khoản khác. Subscribe tại:
# https://rapidapi.com/tikhub-team-tikhub-team-default/api/douyin-api6
# DOUYIN_RAPIDAPI_KEY=

# Lưu ý: hệ thống dùng SQLite (server/db.sqlite), KHÔNG dùng MongoDB.

